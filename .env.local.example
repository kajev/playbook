# ─── Supabase Configuration ───────────────────────────────────────────────────
#
# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API
#
# NEVER commit .env.local to git — it's in .gitignore.
# On Vercel, set these in: Project Settings → Environment Variables.
#
# ─── How to find your values: ─────────────────────────────────────────────────
# 1. Go to https://supabase.com and open your project
# 2. Click "Project Settings" (gear icon) in the left sidebar
# 3. Click "API" under Configuration
# 4. Copy "Project URL" → VITE_SUPABASE_URL
# 5. Copy "anon public" key → VITE_SUPABASE_ANON_KEY
#    (This is the ANON key, NOT the service_role key — never use service_role in frontend)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
