# ─── Dependencies ────────────────────────────────────────────────────────────
# node_modules is never committed — install with `npm install`
node_modules/
.pnp
.pnp.js

# ─── Build Output ─────────────────────────────────────────────────────────────
# Vite builds into /dist — this is what Vercel deploys, not committed to git
dist/
dist-ssr/
build/

# ─── Environment Variables ────────────────────────────────────────────────────
# CRITICAL: .env.local contains your Supabase keys — NEVER commit this.
# Anyone with your Supabase anon key + URL can read/write your database
# (mitigated by RLS, but still not something to expose publicly).
.env.local
.env.*.local

# .env is committed if it only contains public/non-secret variables.
# We don't have a .env file — everything is in .env.local.
# .env

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # Extensions recommendations are fine to share
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store           # macOS folder metadata
Thumbs.db           # Windows thumbnail cache
Desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── TypeScript ───────────────────────────────────────────────────────────────
# TypeScript cache files — regenerated automatically
*.tsbuildinfo

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.local
!.env.local.example    # Keep the example file — it shows devs what vars to set
